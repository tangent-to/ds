{
  "name": "@tangent.to/ds",
  "version": "0.8.3",
  "description": "A minimalist, browser-friendly data-science library in modern JavaScript (ESM)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "browser": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "src",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepare": "npm run build:browser",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "build:browser": "esbuild src/index.js --bundle --platform=browser --format=esm --target=es2020 --outfile=dist/index.js --sourcemap --minify --keep-names --external:@observablehq/plot --external:@tangent.to/*",
    "watch": "esbuild src/index.js --bundle --platform=browser --format=esm --target=es2020 --outfile=dist/index.js --sourcemap --keep-names --watch --external:@observablehq/plot --external:@tangent.to/*",
    "dev": "npm run watch",
    "verify": "node verify-package.js",
    "docs:generate": "node scripts/generate-docs.js",
    "docs:convert": "python3 scripts/convert-notebooks.py",
    "version:bump": "node scripts/bump-version.js",
    "jsr:publish": "deno publish --allow-dirty",
    "jsr:publish:dry-run": "deno publish --dry-run --allow-dirty",
    "deno:lint": "deno lint src/",
    "deno:fmt": "deno fmt src/",
    "deno:check": "deno check src/index.js",
    "docs:api": "node scripts/build-api-docs.mjs",
    "version": "node scripts/sync-version.mjs && git add deno.json"
  },
  "keywords": [
    "data-science",
    "statistics",
    "linear-algebra",
    "regression",
    "machine-learning",
    "esm",
    "browser",
    "typescript-compatible"
  ],
  "author": "Essi Parent",
  "license": "GPL-3.0",
  "homepage": "https://tangent-to.github.io/ds/",
  "repository": {
    "type": "git",
    "url": "https://github.com/tangent-to/ds"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "@tangent.to/opt": "^0.1.0",
    "@tangent.to/proba": "^0.1.0",
    "ml-matrix": "^6.12.1"
  },
  "peerDependencies": {
    "@observablehq/plot": "^0.6.0"
  },
  "peerDependenciesMeta": {
    "@observablehq/plot": {
      "optional": true
    }
  },
  "devDependencies": {
    "@observablehq/plot": "^0.6.17",
    "@vitest/coverage-v8": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "esbuild": "^0.25.11",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "vitest": "^1.6.0"
  }
}
